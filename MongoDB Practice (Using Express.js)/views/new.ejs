<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Write new chat</title>
</head>
<body>
    <h3>Write a new chat</h3>
    <form method="POST" action="/chats">
        <input type="text" name="from" placeholder="Who are you?"><br><br>
        <textarea name="msg" rows="5" cols="30" placeholder="Write a message"></textarea><br><br>
        <input type="text" name="to" placeholder="Receiver"><br><br>
        <button>Submit</button>
    </form>
</body>
</html>